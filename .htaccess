# ============================================
# ANWAAR FOUNDATION - PRODUCTION APACHE CONFIG
# ============================================

Options -Indexes

<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Canonical host: non-www
    RewriteCond %{HTTP_HOST} ^www\.anwaarfoundation\.com$ [NC]
    RewriteRule ^ https://anwaarfoundation.com%{REQUEST_URI} [L,R=301]

    # Prevent old PHP homepage from being served first
    RewriteRule ^index\.php$ /index.html [L,R=301,NC]
</IfModule>

# Ensure the modern homepage file is served by default
DirectoryIndex index.html

<IfModule mod_headers.c>
    Header always set X-Content-Type-Options "nosniff"
    Header always set X-Frame-Options "SAMEORIGIN"
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    Header always set Permissions-Policy "geolocation=(), microphone=(), camera=()"
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On

    ExpiresByType text/html "access plus 0 seconds"
    ExpiresByType text/css "access plus 30 days"
    ExpiresByType application/javascript "access plus 30 days"
    ExpiresByType image/jpeg "access plus 30 days"
    ExpiresByType image/png "access plus 30 days"
    ExpiresByType image/webp "access plus 30 days"
    ExpiresByType video/mp4 "access plus 30 days"
    ExpiresByType image/svg+xml "access plus 30 days"
    ExpiresByType application/font-woff2 "access plus 30 days"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/plain text/html text/css application/javascript application/json image/svg+xml
</IfModule>
